{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksVersion": "1.41.0",
    "config": {
      "phases": {
        "install": {
          "cmds": [
            "npm install -g pnpm@9.15.9",
            "node -e \"console.log(require('child_process').execSync('which pnpm || echo /root/.nvm/versions/node/v20.19.5/bin/pnpm').toString())\"",
            "ln -sf $(which pnpm || echo /root/.nvm/versions/node/v20.19.5/bin/pnpm) /usr/local/bin/pnpm",
            "pnpm i --frozen-lockfile --ignore-scripts"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "pnpm start",
    "restartPolicyType": "ON_FAILURE"
  }
}