{
  "build": {
    "builder": "NIXPACKS",
    "config": {
      "install": {
        "cmds": [
          "corepack enable pnpm",
          "pnpm i --frozen-lockfile --ignore-scripts"
        ]
      }
    }
  },
  "deploy": {
    "startCommand": "pnpm start",
    "restartPolicyType": "ON_FAILURE"
  }
}